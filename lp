<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>【秘密の副業】スマホでこっそり稼ぐ方法</title>
    <style>
        :root {
            --primary: #ff4081;
            /* マダムライブを意識したピンク系 */
            --bg-color: #fafafa;
            --text-main: #333;
            --text-sub: #666;
            --box-bg: #fff;
            --btn-shadow: 0 4px 10px rgba(255, 64, 129, 0.3);
        }

        body {
            font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            line-height: 1.6;
        }

        .container {
            width: 100%;
            max-width: 480px;
            /* スマホファースト */
            background-color: var(--box-bg);
            min-height: 100vh;
            padding-bottom: 40px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.05);
        }

        header {
            background-color: var(--primary);
            color: white;
            padding: 15px;
            text-align: center;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .hero {
            padding: 20px 20px 10px;
            text-align: center;
        }

        .hero h1 {
            font-size: 1.4rem;
            color: var(--primary);
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .hero p {
            font-size: 0.95rem;
            color: var(--text-sub);
        }

        .chat-box {
            background-color: #fce4ec;
            border-radius: 10px;
            padding: 15px;
            margin: 20px;
            position: relative;
        }

        .chat-box::before {
            content: '';
            position: absolute;
            top: -10px;
            left: 20px;
            border-left: 10px solid transparent;
            border-right: 10px solid transparent;
            border-bottom: 10px solid #fce4ec;
        }

        .chat-box p {
            margin: 0 0 10px 0;
            font-weight: bold;
            font-size: 0.95rem;
        }

        .chat-box ul {
            margin: 0;
            padding-left: 20px;
            font-size: 0.9rem;
            color: #444;
        }

        .chat-box li {
            margin-bottom: 5px;
        }

        .content {
            padding: 0 20px;
        }

        .point-section {
            background-color: #fff;
            border: 2px solid #eee;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 25px;
        }

        .point-title {
            color: var(--primary);
            font-weight: bold;
            font-size: 1.1rem;
            text-align: center;
            margin-bottom: 15px;
            border-bottom: 2px dashed #eee;
            padding-bottom: 10px;
        }

        .cta-container {
            text-align: center;
            margin-top: 30px;
            padding: 0 20px;
        }

        .cta-button {
            display: inline-block;
            background: linear-gradient(45deg, #ff4081, #f50057);
            color: white;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: bold;
            padding: 16px 30px;
            border-radius: 30px;
            width: 85%;
            box-shadow: var(--btn-shadow);
            transition: transform 0.2s, box-shadow 0.2s;
            animation: pulse 2s infinite;
        }

        .cta-button:active {
            transform: scale(0.95);
        }

        .cta-subtext {
            display: block;
            margin-top: 10px;
            font-size: 0.8rem;
            color: var(--text-sub);
        }

        .footer-note {
            text-align: center;
            font-size: 0.75rem;
            color: #999;
            margin-top: 40px;
            padding: 0 20px;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.03);
            }

            100% {
                transform: scale(1);
            }
        }

        /* 警告風のアラート */
        .alert-box {
            background-color: #fff3cd;
            color: #856404;
            border-left: 5px solid #ffeeba;
            padding: 10px 15px;
            margin: 20px;
            font-size: 0.85rem;
            border-radius: 4px;
        }
    </style>
</head>

<body>

